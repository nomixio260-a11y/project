{
  "name": "data-saving-browser",
  "version": "0.1.0",
  "description": "Opera Mini-style data-saving proxy browser (server-side fetch, strip, recompress)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && npm run copy:public",
    "copy:public": "node -e \"const fs=require('fs');fs.cpSync('public','dist/public',{recursive:true})\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "install:chromium": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@fastify/compress": "^8.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/static": "^8.0.3",
    "@fastify/websocket": "^11.2.0",
    "cheerio": "^1.0.0",
    "csso": "^5.0.5",
    "fastify": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "html-minifier-terser": "^7.2.0",
    "iconv-lite": "^0.6.3",
    "playwright": "^1.61.0",
    "sharp": "^0.33.5",
    "undici": "^7.2.0"
  },
  "devDependencies": {
    "@types/csso": "^5.0.4",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
